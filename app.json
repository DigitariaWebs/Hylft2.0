{
  "expo": {
    "name": "hylift",
    "slug": "hylift",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/LogoBlue.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE",
      "dark": {
        "image": "./assets/images/LogoBlue.png",
        "backgroundColor": "#0B0D0E"
      }
    },
    "scheme": "hylift",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.hylift",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "NSHealthShareUsageDescription": "Hylift needs access to your health data to track your calories burned, steps, and workouts.",
        "NSHealthUpdateUsageDescription": "Hylift needs to save your workout and nutrition data to Apple Health.",
        "NSCameraUsageDescription": "Hylift uses the camera to scan profile QR codes."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "package": "com.anonymous.hylift"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-health-connect",
        {
          "requestPermissionsOnStart": false
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ],
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Hylift uses the camera to scan profile QR codes."
        }
      ]
    ],
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "1d120403-38ea-4df0-a54f-d53f36e5d531"
      }
    },
    "owner": "achrefdev"
  }
}
